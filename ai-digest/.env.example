# Readwise Reader access token — get it from https://readwise.io/access_token
# (Lives here on the Mac now — NOT in GitHub, since the agent runs locally.)
READWISE_TOKEN=

# --- Local LLM (Gemma via Ollama on this Mac) ---
# Install Ollama (https://ollama.com), then: ollama pull gemma3:12b
# If Ollama isn't reachable, the agent falls back to a transparent heuristic ranker.
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=gemma3:12b
# Context window for ranking ~40 candidates at once. Larger = more RAM.
OLLAMA_NUM_CTX=16384

# How many items to push to Readwise per run. Runs twice a day => ~2x this many daily.
DIGEST_LIMIT=20

# Where saved items land in Reader: new | later | archive | feed
READWISE_LOCATION=feed

# Comma-separated tags applied to every saved item.
READWISE_TAGS=ai-digest

# Engagement feedback loop: skip items already in your Reader library and learn
# from what you've archived/read. Set to 0 to disable.
READWISE_FEEDBACK=1

# --- Optional X/Twitter (off by default) ---
# Needs a self-hosted RSSHub instance; leave blank to skip.
X_RSSHUB_BASE=
X_HANDLES=

# --- Optional local podcast transcription (off by default) ---
# Transcribes recent episodes of podcasts whose show notes lack cited links
# (AI Daily Brief, Everyday AI) with Whisper on this Mac, then Gemma extracts the
# topics discussed to enrich your taste profile. Requires ffmpeg + a Whisper CLI:
#   pip install mlx-whisper        (Apple Silicon)   and   brew install ffmpeg
TRANSCRIBE=0
TRANSCRIBE_LIMIT=1
WHISPER_CMD=mlx_whisper
WHISPER_MODEL=mlx-community/whisper-large-v3-turbo

# Optional: raises the GitHub trending-search rate limit (works unauthenticated too).
GITHUB_TOKEN=

# --- Push notifications (optional) ---
# Get pushes to your phone after each digest via ntfy.sh: install the ntfy app
# (iOS/Android), subscribe to the topic below. Topic is public — pick something
# random/unguessable. Leave blank to disable.
NTFY_TOPIC=
# Override only if you self-host ntfy. Default is the public service.
NTFY_SERVER=https://ntfy.sh
