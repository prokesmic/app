# Readwise Reader access token — get it from https://readwise.io/access_token
READWISE_TOKEN=

# Anthropic API key — used for taste-profile extraction and ranking.
# If omitted, the agent falls back to a transparent heuristic ranker (no LLM).
ANTHROPIC_API_KEY=

# Model used for ranking + taste extraction. Defaults to claude-opus-4-7.
# Set to claude-haiku-4-5 or claude-sonnet-4-6 to cut cost.
DIGEST_MODEL=claude-opus-4-7

# How many items to push to Readwise per run. Runs twice a day => ~2x this many daily.
DIGEST_LIMIT=20

# Where saved items land in Reader: new | later | archive | feed
READWISE_LOCATION=feed

# Comma-separated tags applied to every saved item.
READWISE_TAGS=ai-digest

# Engagement feedback loop: skip items already in your Reader library and learn
# from what you've archived/read. Set to 0 to disable. (Requires READWISE_TOKEN.)
READWISE_FEEDBACK=1

# --- Optional X/Twitter (off by default) ---
# Reading tweets requires a paid X API or a self-hosted RSSHub instance.
# Point this at your RSSHub to pull posts from the handles below; leave blank to skip.
X_RSSHUB_BASE=
# Comma-separated handles (defaults to karpathy,emollick,Citrini7,mattshumer_,jack)
X_HANDLES=

# --- Optional podcast transcription (off by default) ---
# Transcribes recent episodes of podcasts whose show notes lack cited links
# (AI Daily Brief, Everyday AI) via Deepgram, then uses Claude + web search to
# turn the works the hosts discuss into saved articles. Needs ANTHROPIC_API_KEY too.
# Get a key at https://console.deepgram.com — leave blank to skip (no cost).
DEEPGRAM_API_KEY=
# Episodes to transcribe per podcast per run (caps ASR + search cost).
TRANSCRIBE_LIMIT=1

# Optional: raises the GitHub trending-search rate limit (works unauthenticated too).
GITHUB_TOKEN=
