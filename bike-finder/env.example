# Copy to .env and fill in. Never commit the real .env.

# --- Telegram (required to receive alerts) -------------------------------
# 1) Create a bot via @BotFather -> get the token.
# 2) Message your bot once, then get your chat id from
#    https://api.telegram.org/bot<TOKEN>/getUpdates  (look for "chat":{"id":...})
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# --- Optional tuning -----------------------------------------------------
# Minutes between scans in daemon mode (default 30)
SCAN_INTERVAL_MINUTES=30
# Polite delay between HTTP requests in ms (default 1500)
REQUEST_DELAY_MS=1500
# EUR -> CZK conversion for € listings (default 25)
EUR_TO_CZK=25
# Where the dedupe state is stored (default state/seen.json)
STATE_PATH=state/seen.json
