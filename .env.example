# --- Database ---
DATABASE_URL="file:./dev.db"

# --- Mac Studio M3 Ultra monitor: Telegram alerts ---
# 1) Talk to @BotFather -> /newbot -> copy the token here
TELEGRAM_BOT_TOKEN=""
# 2) Message your bot once, then open
#    https://api.telegram.org/bot<TOKEN>/getUpdates and copy chat.id
TELEGRAM_CHAT_ID=""

# Optional second channel
# DISCORD_WEBHOOK_URL=""

# --- Monitor runtime knobs ---
# Shared secret required to trigger POST/GET /api/monitor/run
MONITOR_SECRET=""
# Don't re-alert the same seller within this window (ms). Default 30 min.
MONITOR_ALERT_COOLDOWN_MS="1800000"
# Parallel HTTP checks per run. Default 6.
MONITOR_CONCURRENCY="6"
