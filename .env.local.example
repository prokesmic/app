# Local config for running the monitor on your own machine.
# Copy to .env.local and fill in. .env.local is gitignored and overrides .env.
#
#   cp .env.local.example .env.local

# SQLite database file (relative to the repo root)
DATABASE_URL="file:./dev.db"

# Telegram alerts — from @BotFather (token) and the chat you message the bot from
TELEGRAM_BOT_TOKEN=""
TELEGRAM_CHAT_ID=""

# Optional: don't re-alert the same seller within this window (ms). Default 30 min.
MONITOR_ALERT_COOLDOWN_MS="1800000"
# Optional: parallel HTTP checks per pass. Default 6.
MONITOR_CONCURRENCY="6"
